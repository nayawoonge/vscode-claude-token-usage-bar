{
  "name": "claude-token-usage-bar",
  "displayName": "Claude Token Usage Bar",
  "description": "Show Claude Code context-window usage and today's token consumption in the VS Code status bar.",
  "version": "0.3.1",
  "publisher": "nayawoonge",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nayawoonge/vscode-claude-code-token-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/nayawoonge/vscode-claude-code-token-monitor/issues"
  },
  "homepage": "https://github.com/nayawoonge/vscode-claude-code-token-monitor#readme",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "token",
    "usage",
    "monitor",
    "status bar"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeMonitor.refresh",
        "title": "Claude Token Monitor: Refresh Now"
      },
      {
        "command": "claudeMonitor.toggle",
        "title": "Claude Token Monitor: Show/Hide"
      }
    ],
    "configuration": {
      "title": "Claude Token Monitor",
      "properties": {
        "claudeMonitor.contextWindow": {
          "type": "number",
          "default": 200000,
          "description": "Model context-window size in tokens used to compute the usage bar."
        },
        "claudeMonitor.refreshMs": {
          "type": "number",
          "default": 3000,
          "minimum": 500,
          "description": "How often to re-read the log and refresh the status bar, in milliseconds."
        },
        "claudeMonitor.barWidth": {
          "type": "number",
          "default": 12,
          "minimum": 4,
          "maximum": 40,
          "description": "Width of the bar graph in characters."
        },
        "claudeMonitor.showTodayUsage": {
          "type": "boolean",
          "default": true,
          "description": "Show today's cumulative token usage next to the context bar."
        },
        "claudeMonitor.scope": {
          "type": "string",
          "enum": [
            "workspace",
            "global"
          ],
          "default": "workspace",
          "enumDescriptions": [
            "Context bar tracks the newest session of the currently open workspace's project (closest to 'current session').",
            "Context bar tracks the newest session across all projects."
          ],
          "description": "Which session the context bar reflects."
        },
        "claudeMonitor.alignment": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "Which side of the status bar to place the item on."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.0"
  }
}
